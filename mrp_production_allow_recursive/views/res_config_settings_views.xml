<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_stock_config_settings" model="ir.ui.view">
        <field name="name">res.config.settings</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mrp.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='mrp_reception_report']" position="after">
                <setting
                    id="allow_same_product_component_finish"
                    help="Allow the same product to be used as both a component and a finished product in manufacturing orders."
                >
                    <field name="allow_same_product_component_finish" />
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
